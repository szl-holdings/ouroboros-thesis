      {
        "piece": "proof_route_resolver",
        "status": "needs_code"
      },
      {
        "piece": "domain_pack_dispatcher",
        "status": "needs_code"
      },
      {
        "piece": "golden_run_replay_verifier",
        "status": "needs_code"
      },
      {
        "piece": "almanac_cycle_advancer",
        "status": "needs_code"
      },
      {
        "piece": "health_contract_degrader",
        "status": "needs_code"
      },
      {
        "piece": "operator_approval_gate",
        "status": "needs_code"
      }
    ]
  },
  "output_paths": {
    "trace_jsonl": "output/trace.jsonl",
    "decision_receipt": "output/decision_receipt.json",
    "proof_ledger_jsonl": "output/proof_ledger.jsonl",
    "final_state_json": "output/final_state.json",
    "run_summary_json": "output/run_summary.json",
    "golden_run_report_json": "output/golden_run_report.json"
  },
  "replit_notes": {
    "copy_target": "payload.json",
    "recommended_next_actions": [
      "bind_runner_to_trace_contract_and_output_paths",
      "make_validators_executable",
      "emit_decision_receipts_on_all_high_risk_or_terminal_runs",
      "wire_domain_pack_router_into_dispatch_logic",
      "implement_replay_and_final_state_hash_verification",
      "bind_health_checks_to_advisory_fallback_or_halt",
      "add_operator_approval_gate_ui_or_cli"
    ],
    "safe_for_private_repo": true,
    "purpose": "single master payload to innovate and evolve the full SZL ecosystem from one governed Replit control plane"
  }
}
